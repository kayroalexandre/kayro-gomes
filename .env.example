# =====================================================================
# Kayro Gomes — Portfólio (Payload + Next.js)
# =====================================================================
#
# Este arquivo é o MODELO de variáveis de ambiente.
# O arquivo real (`.env.local`) é gerado por:
#
#     vercel link
#     vercel env pull
#
# Cada ambiente (Development / Preview / Production) tem seu próprio
# conjunto de variáveis na Vercel. Os valores abaixo refletem o que
# é esperado em cada ambiente.
#
# NUNCA commite credenciais reais.

# ---------------------------------------------------------------------
# Banco de dados (Postgres / Neon)
# ---------------------------------------------------------------------
# Em produção, a Vercel injeta o connection string do Neon automaticamente
# (use a branch `main` para prod, `dev` para preview e dev local).
#
# Para Postgres local via docker-compose, use o arquivo `.env.docker`:
#   POSTGRES_URL=postgresql://postgres:postgres@localhost:54320/kayro_local
POSTGRES_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ---------------------------------------------------------------------
# Payload CMS
# ---------------------------------------------------------------------
# Usado para assinar JWTs e criptografar dados sensíveis.
# GERE com: openssl rand -hex 32
PAYLOAD_SECRET=GERE_UMA_STRING_ALEATORIA_DE_64_CARACTERES

# ---------------------------------------------------------------------
# URLs e ambiente
# ---------------------------------------------------------------------
# URL pública do site, sem barra no final.
#   Development: http://localhost:3000
#   Preview:     https://kayro-gomes-<branch>.vercel.app
#   Production:  https://www.kayrogomes.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Ambiente atual: development | preview | production
# Injetado automaticamente pela Vercel via $VERCEL_ENV.
VERCEL_ENV=development

# ---------------------------------------------------------------------
# Segurança
# ---------------------------------------------------------------------
# Token de autorização para os Cron Jobs da Vercel.
# GERE com: openssl rand -hex 32
CRON_SECRET=GERE_OUTRA_STRING_ALEATORIA

# Valida requests do botão "Preview" no admin.
# GERE com: openssl rand -hex 32
PREVIEW_SECRET=GERE_OUTRA_STRING_ALEATORIA

# Senha do usuário de demonstração criado pelo seed (apenas dev/staging).
# Em produção, o seed deve ser pulado ou usar credenciais seguras.
PAYLOAD_DEMO_USER_PASSWORD=

# ---------------------------------------------------------------------
# Vercel Blob Storage
# ---------------------------------------------------------------------
# Token do Vercel Blob (uploads de mídia). Gerado quando você conecta
# o Vercel Blob no painel.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
BLOB_STORE_ID=store_xxx

# ---------------------------------------------------------------------
# Opcional: SMTP para envio de e-mails reais
# ---------------------------------------------------------------------
# Sem isso, Payload só imprime e-mails no console (warning no startup).
# EMAIL_FROM=noreply@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
