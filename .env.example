# === Banco de dados (Postgres / Neon) ===
# Conexão com a branch `main` do Neon em prod, ou um branch `dev` para dev local.
# Para usar Postgres local via docker-compose, aponte para:
#   postgresql://postgres@localhost:54320/kayro_local
POSTGRES_URL=postgresql://user:pass@host:5432/dbname

# === Payload ===
# Usado para assinar JWTs e criptografar dados sensíveis. NÃO compartilhe.
PAYLOAD_SECRET=GERE_UMA_STRING_ALEATORIA_DE_64_CARACTERES

# === Next.js / Payload Admin ===
# URL pública do site, sem barra no final.
# Dev: http://localhost:3000 | Prod: https://seu-dominio.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# === Cron (jobs agendados do Payload) ===
# Header Authorization: Bearer <CRON_SECRET> precisa bater com o configurado no vercel.json
CRON_SECRET=GERE_OUTRA_STRING_ALEATORIA

# === Live preview / Drafts ===
# Valida requests do botão "Preview" no admin.
PREVIEW_SECRET=GERE_OUTRA_STRING_ALEATORIA

# === Vercel Blob Storage (uploads de mídia) ===
# Gerado automaticamente quando você conecta o Vercel Blob no painel.
# NUNCA commite o valor real.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# === Opcional: SMTP para envio de e-mails reais ===
# Sem isso, Payload só imprime e-mails no console (warning no startup).
# EMAIL_FROM=noreply@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
