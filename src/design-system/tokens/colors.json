{
  "$description": "Cores do design system em formato DTCG (designtokens.org). Três camadas: primitive (rampas oklch cruas) → semantic (light/dark/contrast, referenciam primitivos) → component (aliases shadcn/ui, theme-reativos). Inspirado no Simple Design System (github.com/figma/sds).",

  "primitive": {
    "$type": "color",
    "$description": "Rampas de cor cruas (oklch). Não usar diretamente em componentes — referenciar via tokens semânticos.",

    "black": { "$value": "oklch(0% 0 0deg)" },
    "white": { "$value": "oklch(100% 0 0deg)" },

    "red": {
      "50": { "$value": "oklch(97% 0.015 25deg)" },
      "100": { "$value": "oklch(94% 0.04 25deg)" },
      "200": { "$value": "oklch(89% 0.09 25deg)" },
      "300": { "$value": "oklch(82% 0.14 25deg)" },
      "400": { "$value": "oklch(74% 0.19 25deg)" },
      "500": { "$value": "oklch(65% 0.24 25deg)" },
      "600": { "$value": "oklch(55% 0.22 25deg)" },
      "700": { "$value": "oklch(46% 0.19 25deg)" },
      "800": { "$value": "oklch(38% 0.16 25deg)" },
      "900": { "$value": "oklch(28% 0.12 25deg)" },
      "950": { "$value": "oklch(20% 0.09 25deg)" }
    },
    "yellow": {
      "50": { "$value": "oklch(98% 0.02 85deg)" },
      "100": { "$value": "oklch(96% 0.05 85deg)" },
      "200": { "$value": "oklch(93% 0.10 85deg)" },
      "300": { "$value": "oklch(89% 0.15 85deg)" },
      "400": { "$value": "oklch(84% 0.18 85deg)" },
      "500": { "$value": "oklch(78% 0.17 85deg)" },
      "600": { "$value": "oklch(68% 0.15 85deg)" },
      "700": { "$value": "oklch(56% 0.13 85deg)" },
      "800": { "$value": "oklch(45% 0.11 85deg)" },
      "900": { "$value": "oklch(35% 0.09 85deg)" },
      "950": { "$value": "oklch(25% 0.07 85deg)" }
    },
    "green": {
      "50": { "$value": "oklch(97% 0.02 145deg)" },
      "100": { "$value": "oklch(94% 0.05 145deg)" },
      "200": { "$value": "oklch(89% 0.10 145deg)" },
      "300": { "$value": "oklch(82% 0.14 145deg)" },
      "400": { "$value": "oklch(74% 0.17 145deg)" },
      "500": { "$value": "oklch(65% 0.18 145deg)" },
      "600": { "$value": "oklch(55% 0.16 145deg)" },
      "700": { "$value": "oklch(46% 0.14 145deg)" },
      "800": { "$value": "oklch(38% 0.12 145deg)" },
      "900": { "$value": "oklch(28% 0.09 145deg)" },
      "950": { "$value": "oklch(20% 0.07 145deg)" }
    },
    "blue": {
      "50": { "$value": "oklch(97% 0.015 240deg)" },
      "100": { "$value": "oklch(94% 0.04 240deg)" },
      "200": { "$value": "oklch(89% 0.09 240deg)" },
      "300": { "$value": "oklch(82% 0.14 240deg)" },
      "400": { "$value": "oklch(74% 0.18 240deg)" },
      "500": { "$value": "oklch(65% 0.22 240deg)" },
      "600": { "$value": "oklch(55% 0.20 240deg)" },
      "700": { "$value": "oklch(46% 0.17 240deg)" },
      "800": { "$value": "oklch(38% 0.14 240deg)" },
      "900": { "$value": "oklch(28% 0.11 240deg)" },
      "950": { "$value": "oklch(20% 0.08 240deg)" }
    },
    "brand": {
      "$description": "Rampa OFICIAL e definitiva da marca (paleta/escala do brand — NÃO é provisória). Derivada da família azul porém uma rampa INDEPENDENTE: os passos 50–400 coincidem com `blue`, mas de 500 em diante é deliberadamente mais profunda (≈ um passo abaixo do azul; ex.: brand.500 ≈ blue.600), então `blue` e `brand` NÃO são idênticas. brand.500 é a cor BASE da marca (token primary, em ambos os temas). Mantida como rampa própria para evoluir sem migração estrutural.",
      "50": { "$value": "oklch(97% 0.015 240deg)" },
      "100": { "$value": "oklch(94% 0.04 240deg)" },
      "200": { "$value": "oklch(89% 0.09 240deg)" },
      "300": { "$value": "oklch(82% 0.14 240deg)" },
      "400": { "$value": "oklch(74% 0.18 240deg)" },
      "500": { "$value": "oklch(55% 0.20 240deg)" },
      "600": { "$value": "oklch(46% 0.17 240deg)" },
      "700": { "$value": "oklch(38% 0.14 240deg)" },
      "800": { "$value": "oklch(28% 0.11 240deg)" },
      "900": { "$value": "oklch(20% 0.08 240deg)" },
      "950": { "$value": "oklch(12% 0.05 240deg)" }
    },
    "grey": {
      "50": { "$value": "oklch(98.5% 0 0deg)" },
      "100": { "$value": "oklch(96.5% 0 0deg)" },
      "200": { "$value": "oklch(93% 0 0deg)" },
      "300": { "$value": "oklch(88% 0 0deg)" },
      "400": { "$value": "oklch(80% 0 0deg)" },
      "500": { "$value": "oklch(65% 0 0deg)" },
      "600": { "$value": "oklch(50% 0 0deg)" },
      "700": { "$value": "oklch(38% 0 0deg)" },
      "800": { "$value": "oklch(25% 0 0deg)" },
      "900": { "$value": "oklch(15% 0 0deg)" },
      "950": { "$value": "oklch(10% 0 0deg)" }
    }
  },

  "semantic": {
    "$type": "color",
    "$description": "Tokens semânticos por tema (light/dark) + grupo contrast (theme-agnóstico). Referenciam primitivos. Estados: -hover e -active (pressed). No light, estados escurecem (sobe o passo da rampa); no dark, clareiam (desce o passo).",

    "light": {
      "background": {
        "primary": { "$value": "{primitive.grey.50}" },
        "primary-hover": { "$value": "{primitive.grey.100}" },
        "secondary": { "$value": "{primitive.grey.100}" },
        "secondary-hover": { "$value": "{primitive.grey.200}" },
        "tertiary": { "$value": "{primitive.grey.200}" },
        "tertiary-hover": { "$value": "{primitive.grey.300}" },
        "muted": { "$value": "{primitive.grey.300}" },
        "accent": { "$value": "{primitive.green.300}" },
        "accent-hover": { "$value": "{primitive.green.400}" },
        "accent-active": { "$value": "{primitive.green.500}" },
        "brand": { "$value": "{primitive.brand.500}" },
        "brand-hover": { "$value": "{primitive.brand.600}" },
        "brand-active": { "$value": "{primitive.brand.700}" },
        "destructive": { "$value": "{primitive.red.600}" },
        "destructive-hover": { "$value": "{primitive.red.700}" },
        "destructive-active": { "$value": "{primitive.red.800}" },
        "success": { "$value": "{primitive.green.600}" },
        "success-hover": { "$value": "{primitive.green.700}" },
        "warning": { "$value": "{primitive.yellow.600}" },
        "warning-hover": { "$value": "{primitive.yellow.700}" },
        "error": { "$value": "{primitive.red.500}" },
        "error-hover": { "$value": "{primitive.red.600}" },
        "info": { "$value": "{primitive.blue.600}" },
        "info-hover": { "$value": "{primitive.blue.700}" },
        "inverse": { "$value": "{primitive.grey.900}" }
      },
      "foreground": {
        "primary": { "$value": "{primitive.grey.900}" },
        "secondary": { "$value": "{primitive.grey.700}" },
        "tertiary": { "$value": "{primitive.grey.500}" },
        "muted": { "$value": "{primitive.grey.400}" },
        "on-accent": { "$value": "{primitive.black}" },
        "on-brand": { "$value": "{primitive.white}" },
        "on-destructive": { "$value": "{primitive.white}" },
        "on-success": { "$value": "{primitive.white}" },
        "on-warning": { "$value": "{primitive.black}" },
        "on-error": { "$value": "{primitive.white}" },
        "on-info": { "$value": "{primitive.white}" },
        "inverse": { "$value": "{primitive.white}" },
        "brand": { "$value": "{primitive.white}" }
      },
      "border": {
        "primary": { "$value": "{primitive.grey.400}" },
        "secondary": { "$value": "{primitive.grey.300}" },
        "muted": { "$value": "{primitive.grey.200}" },
        "focus": { "$value": "{primitive.black}" },
        "brand": { "$value": "{primitive.brand.400}" },
        "destructive": { "$value": "{primitive.red.600}" }
      }
    },

    "dark": {
      "background": {
        "primary": { "$value": "{primitive.grey.900}" },
        "primary-hover": { "$value": "{primitive.grey.800}" },
        "secondary": { "$value": "{primitive.grey.800}" },
        "secondary-hover": { "$value": "{primitive.grey.700}" },
        "tertiary": { "$value": "{primitive.grey.950}" },
        "tertiary-hover": { "$value": "{primitive.grey.900}" },
        "muted": { "$value": "{primitive.grey.950}" },
        "accent": { "$value": "{primitive.green.500}" },
        "accent-hover": { "$value": "{primitive.green.600}" },
        "accent-active": { "$value": "{primitive.green.700}" },
        "brand": { "$value": "{primitive.brand.500}" },
        "brand-hover": { "$value": "{primitive.brand.400}" },
        "brand-active": { "$value": "{primitive.brand.300}" },
        "destructive": { "$value": "{primitive.red.700}" },
        "destructive-hover": { "$value": "{primitive.red.600}" },
        "destructive-active": { "$value": "{primitive.red.500}" },
        "success": { "$value": "{primitive.green.700}" },
        "success-hover": { "$value": "{primitive.green.600}" },
        "warning": { "$value": "{primitive.yellow.700}" },
        "warning-hover": { "$value": "{primitive.yellow.600}" },
        "error": { "$value": "{primitive.red.600}" },
        "error-hover": { "$value": "{primitive.red.500}" },
        "info": { "$value": "{primitive.blue.500}" },
        "info-hover": { "$value": "{primitive.blue.400}" },
        "inverse": { "$value": "{primitive.white}" }
      },
      "foreground": {
        "primary": { "$value": "{primitive.white}" },
        "secondary": { "$value": "{primitive.grey.300}" },
        "tertiary": { "$value": "{primitive.grey.500}" },
        "muted": { "$value": "{primitive.grey.600}" },
        "on-accent": { "$value": "{primitive.black}" },
        "on-brand": { "$value": "{primitive.white}" },
        "on-destructive": { "$value": "{primitive.white}" },
        "on-success": { "$value": "{primitive.white}" },
        "on-warning": { "$value": "{primitive.black}" },
        "on-error": { "$value": "{primitive.white}" },
        "on-info": { "$value": "{primitive.white}" },
        "inverse": { "$value": "{primitive.grey.900}" },
        "brand": { "$value": "{primitive.white}" }
      },
      "border": {
        "primary": { "$value": "{primitive.grey.800}" },
        "secondary": { "$value": "{primitive.grey.700}" },
        "muted": { "$value": "{primitive.grey.800}" },
        "focus": { "$value": "{primitive.green.400}" },
        "brand": { "$value": "{primitive.brand.300}" },
        "destructive": { "$value": "{primitive.red.700}" }
      }
    },

    "contrast": {
      "$description": "Cores de contraste ABSOLUTAS (não invertem com o tema). Consumidas pelo utilitário de contraste dinâmico (src/utilities/contrast.ts) via --text-on-dark / --text-on-light. Emitidas uma vez em :root.",
      "on-dark": { "$value": "{primitive.grey.50}" },
      "on-dark-muted": { "$value": "{primitive.grey.300}" },
      "on-dark-subtle": { "$value": "{primitive.grey.500}" },
      "on-light": { "$value": "{primitive.grey.900}" },
      "on-light-muted": { "$value": "{primitive.grey.600}" },
      "on-light-subtle": { "$value": "{primitive.grey.500}" }
    }
  },

  "component": {
    "$type": "color",
    "$description": "Camada de compatibilidade shadcn/ui + Tailwind. Cada token mapeia um nome esperado pelo shadcn para um token semântico. O $value é uma referência ESTRUTURAL a {semantic.light...}: o build valida a existência em light E dark e emite uma var theme-reativa (var(--<semantic>)), definida uma única vez. Substitui o antigo aliases.json.",

    "background": { "$value": "{semantic.light.background.primary}" },
    "foreground": { "$value": "{semantic.light.foreground.primary}" },
    "card": { "$value": "{semantic.light.background.secondary}" },
    "card-foreground": { "$value": "{semantic.light.foreground.primary}" },
    "popover": { "$value": "{semantic.light.background.primary}" },
    "popover-foreground": { "$value": "{semantic.light.foreground.primary}" },
    "primary": { "$value": "{semantic.light.background.brand}" },
    "primary-hover": { "$value": "{semantic.light.background.brand-hover}" },
    "primary-active": { "$value": "{semantic.light.background.brand-active}" },
    "primary-foreground": { "$value": "{semantic.light.foreground.on-brand}" },
    "secondary": { "$value": "{semantic.light.background.secondary}" },
    "secondary-hover": { "$value": "{semantic.light.background.secondary-hover}" },
    "secondary-foreground": { "$value": "{semantic.light.foreground.primary}" },
    "muted": { "$value": "{semantic.light.background.muted}" },
    "muted-foreground": { "$value": "{semantic.light.foreground.muted}" },
    "accent": { "$value": "{semantic.light.background.accent}" },
    "accent-hover": { "$value": "{semantic.light.background.accent-hover}" },
    "accent-foreground": { "$value": "{semantic.light.foreground.on-accent}" },
    "destructive": { "$value": "{semantic.light.background.destructive}" },
    "destructive-hover": { "$value": "{semantic.light.background.destructive-hover}" },
    "destructive-foreground": { "$value": "{semantic.light.foreground.on-destructive}" },
    "success": { "$value": "{semantic.light.background.success}" },
    "success-foreground": { "$value": "{semantic.light.foreground.on-success}" },
    "warning": { "$value": "{semantic.light.background.warning}" },
    "warning-foreground": { "$value": "{semantic.light.foreground.on-warning}" },
    "error": { "$value": "{semantic.light.background.error}" },
    "error-foreground": { "$value": "{semantic.light.foreground.on-error}" },
    "info": { "$value": "{semantic.light.background.info}" },
    "info-foreground": { "$value": "{semantic.light.foreground.on-info}" },
    "border": { "$value": "{semantic.light.border.primary}" },
    "input": { "$value": "{semantic.light.border.primary}" },
    "ring": { "$value": "{semantic.light.border.focus}" },
    "brand": { "$value": "{semantic.light.background.brand}" },
    "brand-foreground": { "$value": "{semantic.light.foreground.on-brand}" }
  }
}
