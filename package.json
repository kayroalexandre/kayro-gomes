{
  "name": "with-vercel-website",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "prebuild": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "ci": "payload migrate && bun run build",
    "predev": "bash scripts/ensure-db.sh",
    "dev": "next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && bun run build && bun start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint . --max-warnings 200",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix --max-warnings 200",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "db:check": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/db-check.ts",
    "db:fix-dev-migration": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/db-fix-dev-migration.ts",
    "db:seed": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed.ts",
    "blob:list": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/blob-list.ts",
    "blob:reset": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/blob-reset.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.85.0",
    "@payloadcms/db-vercel-postgres": "3.85.0",
    "@payloadcms/live-preview-react": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/plugin-form-builder": "3.85.0",
    "@payloadcms/plugin-nested-docs": "3.85.0",
    "@payloadcms/plugin-redirects": "3.85.0",
    "@payloadcms/plugin-search": "3.85.0",
    "@payloadcms/plugin-seo": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/storage-vercel-blob": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@vercel/blob": "^2.3.1",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "geist": "^1.7.2",
    "graphql": "^16.14.1",
    "lucide-react": "1.17.0",
    "next": "16.2.7",
    "next-sitemap": "^4.2.3",
    "payload": "3.85.0",
    "pg": "^8.20.0",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/node": "25.9.2",
    "@types/pg": "^8.11.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.0.4",
    "@next/eslint-plugin-next": "16.2.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.2.7",
    "jsdom": "29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.x"
  }
}
